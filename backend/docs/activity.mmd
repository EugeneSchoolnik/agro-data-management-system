stateDiagram-v2
    [*] --> DataCollection: Отримання даних (Go -> Python)
    
    state DataCollection {
        direction LR
        S: Показники датчиків
        W: Прогноз погоди (API)
        S --> Preprocessing
        W --> Preprocessing
    }

    state Preprocessing {
        direction TB
        Norm: Нормалізація даних (0-1)
        Filter: Фільтрація шумів
        Norm --> Filter
    }

    DataCollection --> Preprocessing
    Preprocessing --> ModelExecution: Передача в нейромережу (MLP)

    state ModelExecution {
        direction TB
        Calc: Розрахунок ваг (Weights)
        Softmax: Активація (Probability)
        Calc --> Softmax
    }

    ModelExecution --> ThresholdCheck: Отримання ймовірності (P)

    state ThresholdCheck <<choice>>
    ThresholdCheck --> HighRisk: if P > 0.7
    ThresholdCheck --> LowRisk: if P <= 0.7

    HighRisk --> Notification: Створення термінового сповіщення
    LowRisk --> SaveToDB: Запис у журнал моніторингу

    Notification --> SaveToDB
    SaveToDB --> [*]