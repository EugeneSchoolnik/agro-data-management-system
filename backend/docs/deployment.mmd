graph TD
    subgraph UserDevice [User Device PC/Tablet]
        Browser[Web Browser]
        Svelte[Svelte Frontend App]
    end

    subgraph MainServer [Main Server Cloud/Linux]
        subgraph GoCont [Docker Container: Backend]
            GoBin[Backend.exe Go]
            Service[Service Layer]
            Repo[Repository Layer]
        end
        subgraph DBCont [Docker Container: DB]
            Postgres[PostgreSQL Instance]
        end
    end

    subgraph AIServer [AI Engine Node GPU Server]
        PythonApp[Python AI Service]
        NN[Neural Network LSTM/CNN]
    end

    subgraph IoT [IoT Gateway / Sensors]
        Firmware[Sensor Firmware]
    end

    %% Connections
    UserDevice -- "HTTPS (REST API)" --> MainServer
    GoCont -- "TCP/IP (Port 5432)" --> DBCont
    MainServer -- "HTTP/JSON" --> AIServer
    IoT -- "MQTT / HTTP" --> MainServer